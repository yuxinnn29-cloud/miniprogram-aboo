.container {
  padding: 20rpx;
}

.photo-section {
  margin-bottom: 30rpx;
}

.photo-container {
  position: relative;
  width: 100%;
  height: 500rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-preview {
  width: 100%;
  height: 100%;
}

.retake-button {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
}

.photo-placeholder {
  width: 100%;
  height: 500rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #dcdee0;
}

.placeholder-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #969799;
}

.analyzing {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.form-section {
  margin-bottom: 30rpx;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-buttons van-button {
  flex: 1;
}
