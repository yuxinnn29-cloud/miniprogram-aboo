.container {
  padding-bottom: 100rpx;
}

.photo-section {
  position: relative;
  width: 100%;
  height: 500rpx;
}

.food-photo {
  width: 100%;
  height: 100%;
}

.status-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.days-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background: white;
  margin-bottom: 20rpx;
}

.days-label {
  font-size: 28rpx;
  color: #969799;
  margin-bottom: 16rpx;
}

.days-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #07c160;
}

.days-value.expiring {
  color: #ff976a;
}

.days-value.expired {
  color: #ee0a24;
}

.days-suffix {
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
}

.info-section,
.edit-section {
  margin-bottom: 20rpx;
}

.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: white;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-buttons van-button {
  flex: 1;
}
