<view class="container">
  <!-- 顶部统计 -->
  <view class="stats">
    <view class="stat-item">
      <text class="stat-number">{{foodList.length}}</text>
      <text class="stat-label">总数</text>
    </view>
    <view class="stat-item">
      <text class="stat-number warning">{{expiringFoods.length}}</text>
      <text class="stat-label">即将过期</text>
    </view>
    <view class="stat-item">
      <text class="stat-number danger">{{expiredFoods.length}}</text>
      <text class="stat-label">已过期</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-button">
    <van-button type="primary" size="large" round bindtap="goToAdd">
      添加食物
    </van-button>
  </view>

  <!-- 食物列表 -->
  <view class="food-list" wx:if="{{foodList.length > 0}}">
    <!-- 即将过期 -->
    <view class="section" wx:if="{{expiringFoods.length > 0}}">
      <view class="section-title">即将过期</view>
      <view class="food-item" wx:for="{{expiringFoods}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <van-card
          thumb="{{item.photo}}"
          title="{{item.name}}"
          desc="{{item.storageAdvice}}"
          tag="即将过期"
        >
          <view slot="footer">
            <van-tag type="warning">剩余 {{item.daysRemaining}} 天</van-tag>
          </view>
        </van-card>
      </view>
    </view>

    <!-- 已过期 -->
    <view class="section" wx:if="{{expiredFoods.length > 0}}">
      <view class="section-title">已过期</view>
      <view class="food-item expired" wx:for="{{expiredFoods}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <van-card
          thumb="{{item.photo}}"
          title="{{item.name}}"
          desc="{{item.storageAdvice}}"
          tag="已过期"
        >
          <view slot="footer">
            <van-tag type="danger">已过期 {{-item.daysRemaining}} 天</van-tag>
          </view>
        </van-card>
      </view>
    </view>

    <!-- 正常 -->
    <view class="section" wx:if="{{normalFoods.length > 0}}">
      <view class="section-title">正常</view>
      <view class="food-item" wx:for="{{normalFoods}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <van-card
          thumb="{{item.photo}}"
          title="{{item.name}}"
          desc="{{item.storageAdvice}}"
        >
          <view slot="footer">
            <van-tag type="success">剩余 {{item.daysRemaining}} 天</van-tag>
          </view>
        </van-card>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else>
    <van-empty description="还没有添加食物" />
  </view>
</view>
