<view class="container">
  <!-- 提醒设置 -->
  <view class="section">
    <view class="section-title">提醒设置</view>
    <van-cell-group>
      <van-cell title="提前提醒天数" center>
        <van-stepper
          value="{{ alertDays }}"
          min="1"
          max="30"
          bind:change="onAlertDaysChange"
        />
      </van-cell>
    </van-cell-group>
  </view>

  <!-- API 配置 -->
  <view class="section">
    <view class="section-title">API 配置</view>
    <van-cell-group>
      <van-field
        value="{{ apiKey }}"
        label="API Key"
        placeholder="请输入火山引擎 API Key"
        type="password"
        bind:change="onApiKeyInput"
      />
    </van-cell-group>
    <view class="save-button">
      <van-button type="primary" size="large" round bindtap="saveApiKey">
        保存 API Key
      </van-button>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="section">
    <view class="section-title">数据管理</view>
    <van-cell-group>
      <van-cell title="清空所有数据" is-link bindtap="confirmClearData" />
    </van-cell-group>
  </view>

  <!-- 关于 -->
  <view class="section">
    <view class="section-title">关于</view>
    <van-cell-group>
      <van-cell title="关于小程序" is-link bindtap="showAbout" />
    </van-cell-group>
  </view>
</view>

<van-dialog id="van-dialog" />
