.container {
  padding: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  text-align: center;
}

button {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.image-preview {
  margin: 40rpx 0;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
}

.image-preview image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.image-preview button {
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  margin: 0;
}

.result {
  padding: 30rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}
